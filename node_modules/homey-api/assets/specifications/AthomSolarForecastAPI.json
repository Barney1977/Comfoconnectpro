{
  "host": "solar-forecast-api.athom.com",
  "basePath": "/api/v1/",
  "operations": {
    "getSolarForecast": {
      "path": "/forecast/solar",
      "method": "get",
      "private": true,
      "parameters": {
        "secret": {
          "in": "query",
          "type": "string",
          "required": true
        },
        "lat": {
          "in": "query",
          "type": "number",
          "required": true
        },
        "lng": {
          "in": "query",
          "type": "number",
          "required": true
        },
        "strategy": {
          "in": "query",
          "type": "string"
        },
        "panels": {
          "in": "query",
          "type": "array"
        }
      }
    }
  }
}