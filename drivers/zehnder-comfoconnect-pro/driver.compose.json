{
  "name": {
    "en": "ComfoConnect Pro",
    "nl": "ComfoConnect Pro"
  },
  "class": "fan",
  "connectivity": [
    "lan"
  ],
  "platforms": [
    "local"
  ],
  "energy": {
    "meterPowerImportedCapability": "meter_power"
  },
  "pair": [
    {
      "id": "device",
      "navigation": {
        "next": "list_devices"
      }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "settings": [
    {
      "id": "ip",
      "type": "text",
      "label": {
        "en": "IP Address",
        "nl": "IP-adres"
      },
      "value": "192.168.1.100"
    },
    {
      "id": "port",
      "type": "number",
      "label": {
        "en": "Modbus TCP Port",
        "nl": "Modbus TCP-poort"
      },
      "value": 502
    },
    {
      "id": "unit_id",
      "type": "number",
      "label": {
        "en": "Modbus Unit ID",
        "nl": "Modbus-eenheid-ID"
      },
      "value": 1
    },
    {
      "id": "poll_interval",
      "type": "number",
      "label": {
        "en": "Poll interval (seconds)",
        "nl": "Pollinterval (seconden)"
      },
      "value": 30
    },
    {
      "id": "monitoring_enabled",
      "type": "checkbox",
      "label": {
        "en": "Enable energy & fan monitoring (ComfoConnect protocol)",
        "nl": "Energie- en ventilatiemonitoring inschakelen (ComfoConnect-protocol)"
      },
      "hint": {
        "en": "Uses the binary ComfoConnect protocol (port 56747) to read power usage and fan data. This connection may be briefly interrupted when you open the ComfoControl app or when the Zehnder Cloud connects — it recovers automatically.",
        "nl": "Gebruikt het binaire ComfoConnect-protocol (poort 56747) voor vermogen en ventilatordata. Deze verbinding kan kort worden onderbroken door de ComfoControl-app of Zehnder Cloud — herstel gaat automatisch."
      },
      "value": false
    },
    {
      "id": "comfo_uuid",
      "type": "text",
      "label": {
        "en": "Gateway UUID (auto-filled after first connection)",
        "nl": "Gateway UUID (automatisch ingevuld na eerste verbinding)"
      },
      "hint": {
        "en": "The UUID of your ComfoConnect Pro. Leave empty to auto-discover.",
        "nl": "De UUID van uw ComfoConnect Pro. Leeg laten voor automatische detectie."
      },
      "value": ""
    },
    {
      "id": "reconnect_delay_s",
      "type": "number",
      "label": {
        "en": "Energy reconnect base delay (seconds)",
        "nl": "Basisvertraging herverbinding energie (seconden)"
      },
      "hint": {
        "en": "How long to wait before the first reconnect attempt after session loss. Doubles each attempt up to 5 minutes.",
        "nl": "Wachttijd vóór de eerste herverbindingspoging na sessieverbreking. Verdubbelt per poging tot maximaal 5 minuten."
      },
      "value": 15
    }
  ],
